---
// TODO Refactor
import { Picture } from "astro:assets";
import pfsLogo from "../../assets/logos/pfs.png";
import pfsLogoLimited from "../../assets/logos/pfs_limited.png";
import pfsLogoRestricted from "../../assets/logos/pfs_restricted.png";
import aonLogo from "../../assets/logos/aon.png";
import { getActions, getDuration } from "../../utils";
import Legacy from "../tools/Legacy.astro";
import Trait from "../tools/traits/Trait.astro";

const {
  title,
  traits,
  action,
  legacy,
  level,
  pfs,
  spoiler,
  url,
  area,
  bloodline,
  component,
  cost,
  deity,
  domain,
  duration,
  element,
  legacy_name,
  lesson,
  mystery,
  patron_theme,
  range,
  requirement,
  saving_throw,
  school,
  source,
  spell_type,
  target,
  tradition,
  trigger,
  type,
  primary_check,
  secondary_casters,
  secondary_check,
} = Astro.props;

interface Props {
  title: string;
  traits?: [string, number][];
  action?: number;
  legacy?: boolean;
  level?: number;
  pfs?: string;
  spoiler?: string;
  url?: string;
  area?: string;
  bloodline?: string[];
  component?: string[];
  cost?: string;
  deity?: string[];
  domain?: string[];
  duration?: number;
  element?: string[];
  legacy_name?: string;
  lesson?: string[];
  mystery?: string[];
  patron_theme?: string[];
  range?: number;
  requirement?: string;
  saving_throw?: string;
  school?: string;
  source?: string[];
  spell_type?: string;
  target?: string;
  tradition?: string[];
  trigger?: string;
  type?: string;
  primary_check?: string;
  secondary_casters?: number;
  secondary_check?: string;
}

const getPFS = (pfs: string | undefined) => {
  switch (pfs) {
    case "Limited":
      return pfsLogoLimited;
    case "Restricted":
      return pfsLogoRestricted;
    case "Standard":
      return pfsLogo;
    default:
      return undefined;
  }
};

const pfsImage = getPFS(pfs);
---

  <!--TODO Improve style  -->
{legacy && <Legacy />}
{
  spoiler && (
    <div class="bg-gray-500 text-white flex flex-row items-center justify-center">
      <Fragment set:html={spoiler} />
    </div>
  )
}
<div id="feat-title" class="border-2 rounded-lg border-blue-900">
  <div class="flex flex-row justify-between p-2 items-center bg-blue-900">
    <h3 class="flex flex-row space-x-2 items-center flex-wrap">
      <span class="text-pretty">{title}</span>
      {
        action !== undefined && (
          <span class="action-icon text-xl xl:text-2xl text-white text-wrap">
            {getActions(action)}
          </span>
        )
      }
    </h3>
    <span class="flex flex-row right-2 text-white text-2xl font-bold">
      <span class="hidden md:block mr-2">Level</span>
      <span>{level}</span>
    </span>
  </div>

  <div id="feat-info" class="px-2 mt-1 flex flex-row flex-wrap items-center">
    {
      pfsImage && (
        <Picture
          src={pfsImage}
          title={`PFS: ${pfs}`}
          alt={`PFS: ${pfs}`}
          pictureAttributes={{ class: "m-1 w-8 xl:w-12 mr-2" }}
        />
      )
    }
    {
      traits &&
        traits.length > 0 &&
        traits.map((trait) => (
          <Trait title={trait[0]} rarity={Number(trait[1])} />
        ))
    }
  </div>
  <div class="p-2">
    {area && <div>area: {area}</div>}
    {bloodline && <div>bloodline: {bloodline}</div>}
    {component && <div>component: {component}</div>}
    {cost && <div>cost: {cost}</div>}
    {deity && <div>deity: {deity}</div>}
    {domain && <div>domain: {domain}</div>}
    {duration && <div>duration: {getDuration(duration)}</div>}
    {element && <div>element: {element}</div>}
    {legacy_name && <div>legacy_name: {legacy_name}</div>}
    {lesson && <div>lesson: {lesson}</div>}
    {mystery && <div>mystery: {mystery}</div>}
    {patron_theme && <div>patron_theme: {patron_theme}</div>}
    {range && <div>range: {range}</div>}
    {requirement && <div>requirement: {requirement}</div>}
    {saving_throw && <div>saving_throw: {saving_throw}</div>}
    {school && <div>school: {school}</div>}
    {source && <div>source: {source}</div>}
    {spell_type && <div>spell_type: {spell_type}</div>}
    {target && <div>target: {target}</div>}
    {tradition && <div>tradition: {tradition}</div>}
    {trigger && <div>trigger: {trigger}</div>}
    {type && <div>type: {type}</div>}
    {primary_check && <div>primary_check: {primary_check}</div>}
    {secondary_casters && <div>secondary_casters: {secondary_casters}</div>}
    {secondary_check && <div>secondary_check: {secondary_check}</div>}

    <slot />
    <div id="aon-button" class="flex flex-row-reverse">
      <a
        href={url}
        class="max-w-fit px-3 py-1.5 text-white no-underline bg-blue-900 rounded hover:bg-blue-600 flex flex-row items-center justify-center space-x-2"
        target="_blank">
        <Picture
          src={aonLogo}
          title={"AoN"}
          alt={"AoN"}
          pictureAttributes={{ class: "w-6 md:w-8" }}
        />
        <span class="text-xs md:text-lg font-semibold">{title}</span>
      </a>
    </div>
  </div>
</div>
