---
const { legacy, attr, hp } = Astro.props

import Legacy from '../../../components/tools/Legacy.astro'

interface Props {
    legacy?: boolean,
    attr: string,
    hp: string
}

---

<div class="flex flex-col">
{legacy ? <Legacy/> : null}
<slot name="telling"></slot>

<strong>Key Attribute: {attr}</strong>

At 1st level, your class gives you an ability boost to {attr}

<strong>Hit Points: {hp} plus your Constitution modifier</strong>

You increase your maximum number of HP by this number at 1st level and every level thereafter.

<slot name="key-terms"/>
</div>