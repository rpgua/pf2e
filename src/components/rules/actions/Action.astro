---

import { getActions } from "../../../utils";
import Picture from "astro/components/Picture.astro";
import Legacy from "../../tools/Legacy.astro";
import aonLogo from "../../../assets/logos/aon.png"
import Trait from "../../tools/traits/Trait.astro";
const { title, traits, action, legacy, spoiler, url, level } = Astro.props;

interface Props {
  title: string;
  traits?: [string, number][];
  action?: number;
  legacy?: boolean;
  level?: number;
  pfs?: string;
  spoiler?: string;
  url?: string;
}
---
<!-- TODO pfs level remove -->
{legacy && <Legacy />}
{spoiler && 
<div class="bg-gray-500 text-white flex flex-row items-center justify-center">
  <Fragment set:html={spoiler} />
</div>}
<div id="feat-title" class="border-2 rounded-lg border-blue-900">
  <div class="flex flex-row justify-between p-2 items-center bg-blue-900">
    <h3 class="flex flex-row space-x-2 items-center flex-wrap">
      <span class="text-pretty text-white">{title}</span>
      {action !== undefined && <Fragment set:html={getActions(action)} />} 
    </h3>
    {level !== undefined ? 
      (<span class=" flex flex-row right-2 text-white text-2xl font-bold"> 
      {level === -1 ? <span class="hidden md:block mr-2">Рівень</span> :  
      (level === 0 ? '' : <span class="hidden md:block mr-2">Рівень</span><span>{level}</span>)} </span>) : ''}
  </div>

  <div id="feat-info" class="px-2 mt-1 flex flex-row flex-wrap items-center">
    {traits && traits.length > 0 && (
        traits.map((trait) => (
          <Trait title={trait[0]} rarity={Number(trait[1])} />
        ))
    )}
  </div>
  <div class="p-2">
    <slot />
    {url && <div id="aon-button" class="flex flex-row-reverse">
      <a href={url} class="max-w-fit px-3 py-1.5 no-underline bg-blue-900 rounded hover:bg-blue-600 flex flex-row items-center justify-center space-x-2" target="_blank">
        <Picture
        src={aonLogo}
        title={'AoN'}
        alt={'AoN'}
        pictureAttributes={{ class: "w-6 md:w-8" }}
      /> <span class="text-xs md:text-lg text-white font-semibold">{title}</span>
      </a>
    </div>}
  </div>
  
</div>
